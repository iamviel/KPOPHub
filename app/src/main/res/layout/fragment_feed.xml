<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <View
        android:id="@+id/feedHeader"
        android:layout_width="0dp"
        android:layout_height="132dp"
        android:background="@drawable/background_feed_header"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvFeedTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="30dp"
        android:text="Feed"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPost"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="18dp"
        android:clipToPadding="false"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvFeedTitle"
        tools:listitem="@layout/item_post" />

    <TextView
        android:id="@+id/tvEmptyFeed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No posts yet. Create the first post from Add."
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/rvPost"
        app:layout_constraintEnd_toEndOf="@id/rvPost"
        app:layout_constraintStart_toStartOf="@id/rvPost"
        app:layout_constraintTop_toTopOf="@id/rvPost" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/primary"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/rvPost"
        app:layout_constraintEnd_toEndOf="@id/rvPost"
        app:layout_constraintStart_toStartOf="@id/rvPost"
        app:layout_constraintTop_toTopOf="@id/rvPost" />

</androidx.constraintlayout.widget.ConstraintLayout>
